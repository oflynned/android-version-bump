{
  "name": "android-version-bump",
  "version": "1.2.0",
  "private": false,
  "description": "GitHub action for bumping Android repos using semantic releases.",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "clean": "rimraf lib dist",
    "format": "prettier --write .",
    "lint": "eslint .",
    "package": "ncc build src/main.ts --minify",
    "prepare": "husky",
    "test": "jest",
    "test:e2e": "npm run package && jest --config jest.e2e.config.js --runInBand",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.e2e.json",
    "deps:update": "ncu -u",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "check": "npm run lint && npm run typecheck && npm test -- --runInBand && npm run test:e2e && npm run audit:prod"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oflynned/android-version-bump.git"
  },
  "keywords": [
    "android",
    "semantic",
    "version",
    "release"
  ],
  "author": "Edmond Ó Floinn <oflynned@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@swc/core": "1.15.41",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vercel/ncc": "0.44.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-mock-extended": "4.0.1",
    "lint-staged": "17.0.7",
    "npm-check-updates": "22.2.3",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11",
    "yarn": "please-use-npm"
  }
}
